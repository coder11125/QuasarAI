{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "lib": ["ES2020"],
        "strict": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "moduleResolution": "node",
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "outDir": "./dist",
        "rootDir": "./",
        "forceConsistentCasingInFileNames": true
    },
    "include": ["api/**/*", "lib/**/*"],
    "exclude": ["node_modules", "dist"]
}